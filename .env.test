# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
TAVERNE_URL=https://taverne-des-aventuriers.example.com

MAILER_DSN=null://null

###> symfony/panther ###
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
PANTHER_DEVTOOLS=0
# Point to the Docker-served app when running E2E tests from the host:
PANTHER_EXTERNAL_BASE_URI=http://localhost:8000
PANTHER_CHROME_DRIVER_BINARY=./chromedriver
# Required when Chrome runs outside a proper desktop sandbox (CI, WSL, etc.):
PANTHER_NO_SANDBOX=1
###< symfony/panther ###
