<div id="review-form">
    {% if app.user %}
        <form
            method="POST"
            action="{{ path('app_book_review_submit', {slug: book.slug}) }}"
            data-controller="char-counter"
        >
            <input type="hidden" name="_method" value="POST">
            <input type="hidden" name="_token" id="review_token" value="{{ csrf_token('review_submit') }}">

            <div
                data-controller="shield-selector"
                class="my-rating"
            >
                <div class="my-rating-head">
                    <span class="my-rating-label">Ma note personnelle</span>
                    {% if userReview and userReview.score %}
                        <span class="my-rating-value">
                            <span data-shield-selector-target="display">{{ userReview.score }}</span><span class="denom">&nbsp;/&nbsp;10</span>
                        </span>
                    {% else %}
                        <span class="my-rating-value" style="visibility: hidden">
                            <span data-shield-selector-target="display"></span><span class="denom">&nbsp;/&nbsp;10</span>
                        </span>
                    {% endif %}
                </div>
                <div class="rating-track" role="radiogroup" aria-label="Attribuer une note sur 10">
                    {% for i in 1..10 %}
                        <button
                            type="button"
                            class="rating-pip{% if userReview and userReview.score >= i %} is-on{% endif %}"
                            data-val="{{ i }}"
                            data-shield-selector-target="pip"
                            role="radio"
                            aria-label="Note {{ i }} sur 10"
                            aria-checked="{{ userReview and userReview.score == i ? 'true' : 'false' }}"
                            data-action="click->shield-selector#select keydown->shield-selector#keydown"
                        ></button>
                    {% endfor %}
                    <input
                        type="hidden"
                        name="score"
                        value="{{ userReview ? userReview.score : '' }}"
                        data-shield-selector-target="input"
                    >
                </div>
                <p class="my-rating-help">
                    Clique sur un écusson pour évaluer{% if userReview and userReview.score %} &middot; Mise à jour le {{ userReview.updatedAt|date('d M') }}{% endif %}
                </p>
            </div>

            <div class="my-comment" data-controller="text-formatter">
                <div class="my-comment-head">
                    <span class="my-comment-label">Mon commentaire</span>
                </div>
                <div class="my-comment-frame">
                    <textarea
                        name="comment"
                        class="my-comment-input"
                        rows="4"
                        placeholder="Partage ton impression sur ce livre… (max. 1 000 caractères)"
                        aria-label="Ton commentaire sur ce livre"
                        data-char-counter-target="input"
                        data-text-formatter-target="textarea"
                        data-action="input->char-counter#update"
                    >{{ userReview ? userReview.comment : '' }}</textarea>
                    <div class="my-comment-toolbar">
                        <div class="my-comment-format-btns">
                            <button type="button" class="my-comment-format-btn" title="Gras" data-action="click->text-formatter#bold">
                                <svg viewBox="0 0 24 24" stroke-width="2.5"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
                            </button>
                            <button type="button" class="my-comment-format-btn" title="Italique" data-action="click->text-formatter#italic">
                                <svg viewBox="0 0 24 24" stroke-width="2.5"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
                            </button>
                            <button type="button" class="my-comment-format-btn" title="Citation" data-action="click->text-formatter#quote">
                                <svg viewBox="0 0 24 24" stroke-width="2"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
                            </button>
                            <button type="button" class="my-comment-format-btn" title="Spoiler" data-action="click->text-formatter#spoiler">
                                <svg viewBox="0 0 24 24" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            </button>
                        </div>
                        <span class="my-comment-counter">
                            <span data-char-counter-target="counter">{{ userReview and userReview.comment ? userReview.comment|length : 0 }} / 1000</span>
                        </span>
                    </div>
                </div>
                <div class="my-comment-foot">
                    <div class="my-comment-actions">
                        <button
                            type="submit"
                            class="my-comment-submit"
                            data-char-counter-target="submit"
                        >
                            {{ userReview ? 'Modifier mon avis' : 'Publier mon avis' }}
                        </button>
                        {% if userReview %}
                            <button
                                type="submit"
                                formaction="{{ path('app_book_review_delete', {slug: book.slug, id: userReview.id}) }}"
                                formmethod="POST"
                                name="_method"
                                value="DELETE"
                                class="my-comment-cancel"
                            >Supprimer mon avis</button>
                        {% else %}
                            <button type="reset" class="my-comment-cancel">Effacer</button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </form>
    {% else %}
        <p><a href="{{ path('app_login') }}">Connecte-toi</a> pour noter ce livre.</p>
    {% endif %}
</div>
