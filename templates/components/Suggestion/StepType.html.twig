{% if errors.step1 is defined %}
  <div class="alert alert-warning" role="alert" aria-live="assertive">{{ errors.step1 }}</div>
{% endif %}

{# Mode selection #}
<div class="field-block">
  <div class="field-block-head">
    <div class="ttl">Quel type de proposition&nbsp;? <span class="step">étape 1 / 4</span></div>
  </div>
  <div class="mode-toggle" role="radiogroup" aria-label="Mode de proposition">
    <label data-action="click->live#action"
           data-live-action-param="selectMode"
           data-live-val-param="NEW_ENTRY">
      <input type="radio" name="mode" value="NEW_ENTRY"
             {{ mode == 'NEW_ENTRY' ? 'checked' : '' }}
             aria-label="Nouvelle fiche — Ajouter une entrée encore absente du grimoire" />
      <span class="ic" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
      </span>
      <span class="tx">
        <span class="t">Nouvelle fiche</span>
        <span class="d">Ajouter une entrée encore absente du grimoire.</span>
      </span>
    </label>
    <label data-action="click->live#action"
           data-live-action-param="selectMode"
           data-live-val-param="CORRECTION">
      <input type="radio" name="mode" value="CORRECTION"
             {{ mode == 'CORRECTION' ? 'checked' : '' }}
             aria-label="Corriger une fiche — Améliorer un détail sur une fiche existante" />
      <span class="ic" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M3 17l6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>
      </span>
      <span class="tx">
        <span class="t">Corriger une fiche</span>
        <span class="d">Améliorer un détail sur une fiche existante.</span>
      </span>
    </label>
  </div>
</div>

{# Correction source banner #}
{% if mode == 'CORRECTION' %}
  <div class="correction-prefill" role="status" aria-label="Fiche source de la correction"
       {{ stimulus_controller('suggestion-fiche-picker', {
         searchUrl: path('app_suggestions_source_search')
       }) }}>
    {% if sourceEntityId %}
      <div class="pf-cover" aria-hidden="true"></div>
      <div class="pf-text">
        <div class="pf-eyebrow">★ Fiche source · pré-remplie</div>
        <div class="pf-title">{{ formData.title ?? formData.name ?? 'Fiche sélectionnée' }}</div>
        <div class="pf-meta">
          {{ formData.author ?? '' }}
          {% if formData.publicationFr is defined and formData.publicationFr %}· {{ formData.publicationFr }}{% endif %}
        </div>
      </div>
      <button type="button" class="pf-change"
              {{ stimulus_action('suggestion-fiche-picker', 'open') }}
              aria-label="Changer de fiche source" aria-haspopup="dialog">
        Changer<br/>de fiche
      </button>
    {% else %}
      <div class="pf-cover" aria-hidden="true"></div>
      <div class="pf-text">
        <div class="pf-eyebrow">Fiche source</div>
        <div class="pf-title" style="color: var(--ink-muted); font-weight: 400;">Aucune fiche sélectionnée</div>
        <div class="pf-meta">Choisissez une fiche existante à corriger.</div>
      </div>
      <button type="button" class="pf-change"
              {{ stimulus_action('suggestion-fiche-picker', 'open') }}
              aria-label="Choisir une fiche source" aria-haspopup="dialog">
        Choisir<br/>une fiche
      </button>
    {% endif %}

    {# Hidden confirm trigger for live action #}
    <button type="button" hidden
            data-action="live#action"
            data-live-action-param="setSourceById"
            data-live-type-param=""
            data-live-id-param=""
            {{ stimulus_target('suggestion-fiche-picker', 'confirmBtn') }}></button>

    {# Fiche picker modal #}
    <div class="fiche-picker" role="dialog" aria-modal="true" aria-labelledby="fp-title"
         {{ stimulus_target('suggestion-fiche-picker', 'modal') }}>
      <div class="fp-dialog">
        <div class="fp-head">
          <div class="fp-titles">
            <div class="fp-eyebrow">Correction · Fiche source</div>
            <h2 id="fp-title">Choisir la fiche à corriger</h2>
            <div class="fp-sub">Le formulaire sera pré-rempli avec les données de la fiche sélectionnée.</div>
          </div>
          <button type="button" class="fp-close" {{ stimulus_action('suggestion-fiche-picker', 'close') }} aria-label="Fermer">
            <svg viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="fp-search">
          <svg class="fp-loupe" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          <input type="search" placeholder="Rechercher un titre, un auteur, un ISBN…"
                 aria-label="Rechercher une fiche"
                 {{ stimulus_target('suggestion-fiche-picker', 'searchInput') }}
                 {{ stimulus_action('suggestion-fiche-picker', 'search', 'input') }} />
        </div>

        <div class="fp-scope">
          <button type="button" aria-pressed="true" data-scope="ALL"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Tout</button>
          <button type="button" aria-pressed="false" data-scope="BOOK"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Livres</button>
          <button type="button" aria-pressed="false" data-scope="AUTHOR"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Auteurs</button>
          <button type="button" aria-pressed="false" data-scope="ILLUSTRATOR"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Illustrateurs</button>
          <button type="button" aria-pressed="false" data-scope="TRADUCTOR"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Traducteurs</button>
          <button type="button" aria-pressed="false" data-scope="COLLECTION"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Collections</button>
          <button type="button" aria-pressed="false" data-scope="EDITOR"
                  {{ stimulus_action('suggestion-fiche-picker', 'setScope') }}>Éditeurs</button>
        </div>

        <div class="fp-list" {{ stimulus_target('suggestion-fiche-picker', 'list') }}>
          <div class="fp-group">Consultés récemment</div>
          <div class="fp-empty">Aucun résultat pour cette recherche.</div>
        </div>

        <div class="fp-foot">
          <span class="fp-hint">
            <kbd>↵</kbd> Sélectionner · <kbd>Échap</kbd> Fermer
          </span>
          <button type="button" class="btn btn-secondary btn-sm fp-create-link"
                  {{ stimulus_action('suggestion-fiche-picker', 'close') }}>
            + Créer une nouvelle fiche
          </button>
        </div>
      </div>
    </div>
  </div>
{% endif %}

{# Entity type selection #}
{% set entityTypes = [
  {value: 'BOOK',        label: 'Livre',        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="13" y2="11"/></svg>'},
  {value: 'AUTHOR',     label: 'Auteur',       icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="4"/><path d="M4 21v-2a7 7 0 0 1 14 0v2"/></svg>'},
  {value: 'ILLUSTRATOR',label: 'Illustrateur', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>'},
  {value: 'TRADUCTOR',  label: 'Traducteur',   icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/></svg>'},
  {value: 'EDITOR',     label: 'Éditeur',      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>'},
  {value: 'COLLECTION', label: 'Collection',   icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="5" height="18" rx="1"/><rect x="9.5" y="3" width="5" height="18" rx="1"/><rect x="17" y="3" width="5" height="18" rx="1"/></svg>'},
] %}

{% if mode == 'CORRECTION' %}
  <div class="field-block">
    <div class="field-block-head">
      <div class="ttl">Type de fiche</div>
      <div class="hint">Déterminé par la fiche source.</div>
    </div>
    <div class="type-grid" aria-label="Type de fiche (verrouillé)">
      {% for et in entityTypes %}
        <div class="type-card {{ entityType == et.value ? 'type-card--locked-active' : 'type-card--locked' }}"
             aria-label="{{ et.label }}">
          <span class="ic" aria-hidden="true">{{ et.icon|raw }}</span>
          <span class="lbl">{{ et.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% else %}
  <div class="field-block">
    <div class="field-block-head">
      <div class="ttl">Type de fiche <span class="req">obligatoire</span></div>
      <div class="hint">Détermine les champs à remplir.</div>
    </div>
    <div class="type-grid" role="radiogroup" aria-label="Type d'entité à soumettre" aria-required="true">
      {% for et in entityTypes %}
        <label class="type-card">
          <input type="radio" name="entityType" value="{{ et.value }}"
                 data-model="on(change)|entityType"
                 aria-label="{{ et.label }}" />
          <span class="ic" aria-hidden="true">{{ et.icon|raw }}</span>
          <span class="lbl">{{ et.label }}</span>
        </label>
      {% endfor %}
    </div>
  </div>
{% endif %}
