<div {{ attributes }}
     {{ stimulus_controller('suggestion-abandon') }}>

  {# Step progress indicator #}
  <ol class="form-stepper" aria-label="Étapes de création">
    {% for i in 1..4 %}
      {% set stepLabels = {1: 'Type', 2: 'Détails', 3: 'Couverture', 4: 'Aperçu'} %}
      <li class="step-item {{ step > i ? 'done' : '' }} {{ step == i ? 'current' : '' }}"
          {% if step == i %}aria-current="step"{% endif %}
          {% if step < i %}aria-disabled="true"{% endif %}>
        <span class="dot"><span aria-hidden="true">{{ i }}</span></span>
        <span class="label">{{ stepLabels[i] }}</span>
      </li>
      {% if i < 4 %}<li class="step-line" aria-hidden="true"></li>{% endif %}
    {% endfor %}
  </ol>

  <div class="panel-body">
    {# Error flash #}
    {% if errors.submit is defined %}
      <div class="alert alert-danger" role="alert" aria-live="assertive">{{ errors.submit }}</div>
    {% endif %}

    {# Step content #}
    {% if step == 1 %}
      {{ include('components/Suggestion/StepType.html.twig') }}
    {% elseif step == 2 %}
      {{ include('components/Suggestion/StepForm.html.twig') }}
    {% elseif step == 3 %}
      {{ include('components/Suggestion/StepCover.html.twig') }}
    {% elseif step == 4 %}
      {{ include('components/Suggestion/StepPreview.html.twig') }}
    {% endif %}
  </div>

  {# Wizard footer navigation #}
  <div class="wizard-foot">
    {% if step > 1 %}
      <button type="button" class="btn btn-secondary btn-sm"
              data-action="live#action"
              data-live-action-param="goToStep"
              data-live-step-param="{{ step - 1 }}">
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        Précédent
      </button>
    {% endif %}

    <span class="wf-meta">
      Étape {{ step }} / 4 · Auto-sauvegardé
    </span>

    {% if step < 4 %}
      <button type="button" class="btn btn-primary btn-sm"
              data-action="live#action"
              data-live-action-param="nextStep"
              {{ (step == 1 and (mode is null or entityType is null)) ? 'disabled' : '' }}>
        Suivant
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    {% else %}
      <button type="button" class="btn btn-primary btn-sm {{ not canSubmit ? 'is-submit' : '' }}"
              data-action="live#action"
              data-live-action-param="submitSuggestion"
              {{ not canSubmit ? 'disabled' : '' }}>
        Soumettre
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    {% endif %}
  </div>

</div>
