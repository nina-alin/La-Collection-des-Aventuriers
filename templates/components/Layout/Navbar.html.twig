{% set path = app.request.pathInfo %}

{# Desktop header #}
<header class="lp-header d-none d-md-block">
    <div class="container lp-header-inner">
        <a class="lp-brand" href="{{ path('home') }}">
            <span class="sigil">A</span>
            <span class="lp-brand-text">
                <span class="lp-brand-title">La Collection</span>
                <span class="lp-brand-sub">Wiki des fictions interactives</span>
            </span>
        </a>
        <nav aria-label="Navigation principale">
            <ul class="lp-nav-links">
                <li>
                    <a href="{{ path('home') }}"
                       class="lp-nav-link{% if path == '/' %} active{% endif %}"
                       {% if path == '/' %}aria-current="page"{% endif %}>
                        Accueil
                    </a>
                </li>
                <li>
                    <a href="{{ path('catalogue_index') }}"
                       class="lp-nav-link{% if path starts with '/catalogue' %} active{% endif %}"
                       {% if path starts with '/catalogue' %}aria-current="page"{% endif %}>
                        Catalogue
                    </a>
                </li>
                <li>
                    <a href="{{ path('suggestions_index') }}"
                       class="lp-nav-link{% if path starts with '/suggestions' %} active{% endif %}"
                       {% if path starts with '/suggestions' %}aria-current="page"{% endif %}>
                        Suggestions
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

{# Mobile top bar #}
<div class="lp-mobile-topbar d-flex d-md-none">
    <a class="lp-brand" href="{{ path('home') }}">
        <span class="sigil">A</span>
        <span class="lp-brand-title">La Collection</span>
    </a>
    <button class="btn-icon btn-ghost lp-notif-btn" aria-label="Notifications" type="button">
        <i class="bi bi-bell"></i>
    </button>
</div>

{# Mobile bottom nav #}
<nav class="bottom-nav d-block d-md-none" aria-label="Navigation mobile">
    <a href="{{ path('home') }}"
       class="bottom-nav-item{% if path == '/' %} active{% endif %}"
       {% if path == '/' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M3 12L12 4l9 8"/><path d="M5 10v10a1 1 0 0 0 1 1h4v-7h4v7h4a1 1 0 0 0 1-1V10"/></svg>
        Accueil
    </a>
    <a href="{{ path('catalogue_index') }}"
       class="bottom-nav-item{% if path starts with '/catalogue' %} active{% endif %}"
       {% if path starts with '/catalogue' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M4 6a2 2 0 0 1 2-2h11v16H6a2 2 0 0 1-2-2z"/><path d="M17 4v16M9 8h5M9 12h5"/></svg>
        Catalogue
    </a>
    <a href="{{ path('suggestions_new') }}"
       class="bottom-nav-item"
       aria-label="Suggérer un livre">
        <span class="bottom-nav-fab">
            <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
        </span>
    </a>
    <a href="{{ path('suggestions_index') }}"
       class="bottom-nav-item{% if path starts with '/suggestions' %} active{% endif %}"
       {% if path starts with '/suggestions' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M19 14c1.5-2.5 1-6-1-8s-5.5-2.5-8-1-3.5 5-2 7.5L4 19l6.5-4c2.5 1.5 6 1 8.5-1z"/></svg>
        Suggestions
    </a>
    <a href="#profil" class="bottom-nav-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
        Profil
    </a>
</nav>
