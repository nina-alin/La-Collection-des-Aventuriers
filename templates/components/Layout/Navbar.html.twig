{% set path = app.request.pathInfo %}

{# Desktop header #}
<header class="lp-header d-none d-md-block">
    <div class="container lp-header-inner">
        <a class="lp-brand" href="{{ path('home') }}">
            <span class="sigil">A</span>
            <span class="lp-brand-text d-none d-xl-flex">
                <span class="lp-brand-title">La Collection des Aventuriers</span>
                <span class="lp-brand-sub">Wiki des fictions interactives</span>
            </span>
        </a>
        <nav aria-label="Navigation principale">
            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                <ul class="lp-nav-links">
                    <li>
                        <a href="{{ path('home') }}"
                           class="lp-nav-link{% if path == '/' %} active{% endif %}"
                           {% if path == '/' %}aria-current="page"{% endif %}>
                            Accueil
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_catalogue') }}"
                           class="lp-nav-link{% if path starts with '/catalogue' %} active{% endif %}"
                           {% if path starts with '/catalogue' %}aria-current="page"{% endif %}>
                            Catalogue
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('suggestions_index') }}"
                           class="lp-nav-link{% if path starts with '/suggestions' %} active{% endif %}"
                           {% if path starts with '/suggestions' %}aria-current="page"{% endif %}>
                            Suggestions
                        </a>
                    </li>
                </ul>
            {% endif %}
        </nav>
        {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
        <form class="sh-search"
              data-controller="search"
              data-search-url-livre-value="{{ path('app_book_show', {slug: '__SLUG__'}) }}"
              data-search-url-collection-value="{{ path('app_collection_show', {slug: '__SLUG__'}) }}"
              data-search-url-auteur-value="{{ path('app_author_show', {slug: '__SLUG__'}) }}"
              data-search-catalogue-value="{{ path('app_catalogue') }}"
              role="search" action="" novalidate>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            <input type="search"
                   data-search-target="input"
                   role="combobox"
                   aria-expanded="false"
                   aria-controls="search-listbox"
                   aria-haspopup="listbox"
                   aria-autocomplete="list"
                   aria-label="Recherche globale"
                   placeholder="Rechercher un livre, un auteur, une collection…"
                   autocomplete="off">
            <div class="search-dropdown" hidden data-search-target="panel">
                <div class="search-dd-head" data-search-target="head"></div>
                <div class="search-dd-body">
                    <div id="search-listbox" role="listbox" data-search-target="results"></div>
                </div>
                <div class="search-dd-foot" data-search-target="foot"></div>
            </div>
            <span class="visually-hidden" data-search-target="status" aria-live="polite" aria-atomic="true"></span>
        </form>
        {% endif %}
        <div class="lp-header-actions">
            <button class="lp-theme-toggle"
                    data-action="click->theme#toggle"
                    aria-label="Basculer le thème"
                    aria-pressed="false">
                <i class="bi bi-moon-fill" aria-hidden="true"></i>
            </button>
            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                {% if is_granted('ROLE_USER') %}
                    <twig:Notification:NotificationPanelComponent />
                {% endif %}
                <twig:Layout:ProfileMenu instanceId="desktop" />
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-sm btn-secondary">Se connecter</a>
            {% endif %}
        </div>
    </div>
</header>

{# Mobile top bar #}
<div class="lp-mobile-topbar d-flex d-md-none">
    <a class="lp-brand" href="{{ path('home') }}">
        <span class="sigil">A</span>
        <span class="lp-brand-title">La Collection</span>
    </a>
    {# Spacer keeps layout balanced; actual trigger rendered below outside backdrop-filter context #}
    <div style="width:44px;height:44px;"></div>
</div>

{# Mobile user menu — rendered OUTSIDE .lp-mobile-topbar to avoid backdrop-filter containing-block bug
   (backdrop-filter on the topbar makes position:fixed children relative to topbar, not viewport) #}
{% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
<div class="lp-mobile-user-menu d-flex gap-3 d-md-none">
    <button class="lp-theme-toggle"
            data-action="click->theme#toggle"
            aria-label="Basculer le thème"
            aria-pressed="false">
        <i class="bi bi-moon-fill" aria-hidden="true"></i>
    </button>
    {% if is_granted('ROLE_USER') %}
        <twig:Notification:NotificationPanelComponent />
    {% endif %}
    <twig:Layout:ProfileMenu instanceId="mobile" />
</div>
{% else %}
<div class="lp-mobile-user-menu d-flex gap-3 d-md-none">
    <button class="lp-theme-toggle"
            data-action="click->theme#toggle"
            aria-label="Basculer le thème"
            aria-pressed="false">
        <i class="bi bi-moon-fill" aria-hidden="true"></i>
    </button>
    <a href="{{ path('app_login') }}" class="btn btn-sm btn-secondary">Se connecter</a>
</div>
{% endif %}

{# Mobile bottom nav #}
<nav class="bottom-nav d-flex d-md-none" aria-label="Navigation mobile">
    <a href="{{ path('home') }}"
       class="bottom-nav-item{% if path == '/' %} active{% endif %}"
       {% if path == '/' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M3 12L12 4l9 8"/><path d="M5 10v10a1 1 0 0 0 1 1h4v-7h4v7h4a1 1 0 0 0 1-1V10"/></svg>
        Accueil
    </a>
    <a href="{{ path('app_catalogue') }}"
       class="bottom-nav-item{% if path starts with '/catalogue' %} active{% endif %}"
       {% if path starts with '/catalogue' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M4 6a2 2 0 0 1 2-2h11v16H6a2 2 0 0 1-2-2z"/><path d="M17 4v16M9 8h5M9 12h5"/></svg>
        Catalogue
    </a>
    <a href="{{ path('suggestions_index') }}"
       class="bottom-nav-item{% if path starts with '/suggestions' %} active{% endif %}"
       {% if path starts with '/suggestions' %}aria-current="page"{% endif %}>
        <svg viewBox="0 0 24 24"><path d="M19 14c1.5-2.5 1-6-1-8s-5.5-2.5-8-1-3.5 5-2 7.5L4 19l6.5-4c2.5 1.5 6 1 8.5-1z"/></svg>
        Suggestions
    </a>
    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
    <div class="bottom-nav-item" style="padding:0">
        <form method="POST" action="{{ path('app_logout') }}" style="margin:0;display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px 4px;width:100%">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button type="submit" style="background:none;border:none;display:flex;flex-direction:column;align-items:center;gap:2px;color:inherit;font-size:inherit;cursor:pointer;padding:0;width:100%">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Déconnexion
            </button>
        </form>
    </div>
    {% else %}
    <a href="{{ path('app_login') }}" class="bottom-nav-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
        Connexion
    </a>
    {% endif %}
</nav>
