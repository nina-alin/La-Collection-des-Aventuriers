{% set typeClass = type == 'error' ? 'danger' : type %}
{% set icons = {'success': '✓', 'danger': '✕', 'warning': '!', 'info': 'i'} %}
<div {{ stimulus_controller('toast', {autoDismissMs: autoDismissMs}) }}
     class="toast {{ cssClass|default(typeClass) }}"
     {{ typeClass in ['danger', 'warning'] ? 'role="alert"' : 'role="status"' }}>
    <span class="toast-icon">{{ icons[typeClass]|default('i') }}</span>
    <div class="toast-body">
        {% if title %}
            <span class="toast-title">{{ title|e }}</span>
            <span class="toast-message">{{ message|e }}</span>
        {% else %}
            <span class="toast-title">{{ message|e }}</span>
        {% endif %}
    </div>
    <button class="toast-close"
            {{ stimulus_action('toast', 'close') }}
            type="button"
            aria-label="Fermer">
        <svg viewBox="0 0 24 24"><path d="M6 6l12 12M6 18L18 6"/></svg>
    </button>
    <span class="toast-timer"></span>
</div>
