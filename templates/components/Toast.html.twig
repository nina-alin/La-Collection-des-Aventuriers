<div {{ stimulus_controller('toast', {autoDismissMs: autoDismissMs}) }}
     class="toast {{ cssClass|default('toast--' ~ type) }}"
     {{ type in ['error', 'warning'] ? 'role="alert"' : 'role="status"' }}>
    <button class="toast-close"
            {{ stimulus_action('toast', 'close') }}
            type="button"
            aria-label="Fermer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <span class="toast-type-label">{{ type|capitalize }}</span>
    {% if title %}<strong class="toast-title">{{ title|e }}</strong>{% endif %}
    <span class="toast-message">{{ message|e }}</span>
</div>
