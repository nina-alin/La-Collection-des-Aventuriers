{% if loading %}
<div class="card-book card-book--skeleton">
    <div class="cover cover--skeleton"></div>
    <div class="body">
        <div class="skeleton-line skeleton-line--title"></div>
        <div class="skeleton-line skeleton-line--meta"></div>
        <div class="skeleton-line skeleton-line--short"></div>
    </div>
</div>
{% else %}
<div class="card-book"{% if bookId %} aria-label="{{ title }}"{% endif %}>
    <div class="cover">
        {% if coverUrl %}
            <img src="{{ coverUrl }}" alt="{{ title }}" loading="lazy">
        {% else %}
            <div class="cover-gradient">
                <div class="cover-frame"></div>
                <span class="cover-title">{{ title }}</span>
            </div>
        {% endif %}
    </div>
    <div class="body">
        {% if bookId %}
            <a href="{{ path('home') }}" class="title" aria-label="{{ title }}">{{ title }}</a>
        {% else %}
            <span class="title">{{ title }}</span>
        {% endif %}
        <span class="author">{{ author }}</span>
        {% if rating is not null %}
            <twig:Rating :value="rating" size="sm" />
        {% endif %}
    </div>
</div>
{% endif %}
