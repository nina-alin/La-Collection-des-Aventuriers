{% if loading %}
<div class="card card-book card-book--skeleton">
    <div class="cover cover--skeleton"></div>
    <div class="body">
        <div class="skeleton-line skeleton-line--title"></div>
        <div class="skeleton-line skeleton-line--meta"></div>
        <div class="skeleton-line skeleton-line--short"></div>
    </div>
</div>
{% else %}
{% if isWishlist and bookId %}
<form id="wl-card-{{ bookId }}" method="post" action="{{ path('app_userbook_remove_wishlist', {id: bookId}) }}" hidden>
    <input type="hidden" name="_token" value="{{ csrf_token('remove_wishlist_' ~ bookId) }}">
</form>
{% endif %}
{% if bookId and app.user %}
<form id="fav-card-{{ bookId }}" method="post" action="{{ path('app_userbook_toggle_favorite', {id: bookId}) }}" hidden>
    <input type="hidden" name="_token" value="{{ csrf_token('toggle_favorite_' ~ bookId) }}">
</form>
<form id="own-card-{{ bookId }}" method="post" action="{{ path('app_userbook_toggle_owned', {id: bookId}) }}" hidden>
    <input type="hidden" name="_token" value="{{ csrf_token('toggle_owned_' ~ bookId) }}">
</form>
{% endif %}
{% set href = (bookId and slug) ? path('app_book_show', {slug: slug}) : '#' %}
<div class="card card-book{{ isMissing ? ' card-book--missing' : '' }}">
    <div class="cover">
        <span class="cover-bookmark" aria-hidden="true"></span>
        <span class="cover-frame" aria-hidden="true"></span>
        {% if collectionRef %}
            <span class="cover-ref">{{ collectionRef }}</span>
        {% endif %}
        {% if coverUrl %}
            <img src="{{ coverUrl }}" alt="{{ title }}" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;">
        {% endif %}
        <span class="cover-title" style="position:relative;z-index:1;">{{ title }}</span>
    </div>
    {% if isWishlist and bookId %}
    <div class="card-wishlist-bar">
        <span class="card-wishlist-label">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            Dans ma liste d'achat
        </span>
        <button type="submit" form="wl-card-{{ bookId }}" class="card-wishlist-btn">Retirer</button>
    </div>
    {% endif %}
    <div class="body">
        {% if editionInfo is not null or publicationYear is not null %}
        <div class="ref-edition">
            <span>{{ editionInfo ?? '' }}</span>
            {% if publicationYear is not null %}<span>{{ publicationYear }}</span>{% endif %}
        </div>
        {% endif %}
        <div class="title">{{ title }}</div>
        <div class="author">{{ author }}</div>
    </div>
    <div class="footer">
        {% if rating is not null %}
        <span class="score-pill">
            <span class="shield" aria-hidden="true"></span>
            {{ rating|number_format(1) }} <span class="score-out">/ 10</span>
        </span>
        {% else %}
        <span class="score-pill" style="opacity:0.35;">
            <span class="shield" aria-hidden="true"></span>
            – <span class="score-out">/ 10</span>
        </span>
        {% endif %}
        <div class="footer-actions">
            {% if bookId and app.user %}
                <button class="icon-btn-sm{{ isFavorite ? ' is-on' : '' }}" type="submit" form="fav-card-{{ bookId }}" aria-label="Favori">
                    <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.5-9.5-9C1 8.5 3 5 6.5 5c2 0 3.5 1 5.5 3 2-2 3.5-3 5.5-3C21 5 23 8.5 21.5 12 19 16.5 12 21 12 21z"/></svg>
                </button>
                <button class="icon-btn-sm{{ isOwned ? ' is-on' : '' }}" type="submit" form="own-card-{{ bookId }}" aria-label="{{ isOwned ? 'Retirer de ma collection' : 'Ajouter à ma collection' }}">
                    <svg viewBox="0 0 24 24"><path d="{{ isOwned ? 'M5 13l4 4L19 7' : 'M12 5v14M5 12h14' }}"/></svg>
                </button>
            {% else %}
                <button class="icon-btn-sm" type="button" aria-label="Favori" tabindex="-1">
                    <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.5-9.5-9C1 8.5 3 5 6.5 5c2 0 3.5 1 5.5 3 2-2 3.5-3 5.5-3C21 5 23 8.5 21.5 12 19 16.5 12 21 12 21z"/></svg>
                </button>
                <button class="icon-btn-sm" type="button" aria-label="Ajouter" tabindex="-1">
                    <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                </button>
            {% endif %}
        </div>
    </div>
    <a class="card-link" href="{{ href }}"{% if bookId %} aria-label="{{ title }}"{% endif %}></a>
</div>
{% endif %}
