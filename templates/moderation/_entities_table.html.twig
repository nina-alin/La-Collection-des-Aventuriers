{% for entity in entities %}
<tr>
    <td style="padding:.5rem;border-bottom:1px solid var(--border-default)">{{ entity.name }}</td>
    <td style="padding:.5rem;border-bottom:1px solid var(--border-default)">{{ entity.type }}</td>
    <td style="padding:.5rem;border-bottom:1px solid var(--border-default)">{{ entity.status }}</td>
    <td style="padding:.5rem;border-bottom:1px solid var(--border-default)">{{ entity.updatedAt|date('d/m/Y') }}</td>
    <td style="padding:.5rem;border-bottom:1px solid var(--border-default);display:flex;gap:.375rem;justify-content:flex-end">
        <a href="#" class="btn btn-sm btn-ghost" title="Modifier">✏️</a>
        <button
            class="btn btn-sm btn-secondary"
            title="Supprimer / Dépublier"
            data-action="click->moderation-room#openDeleteModal"
            data-entity-id="{{ entity.id }}"
            data-entity-type="{{ entity.type }}"
            data-entity-name="{{ entity.name }}"
        >🗑</button>
        {% if entity.refusalReason is defined and entity.refusalReason is not null %}
        <button
            class="btn btn-sm btn-ghost"
            title="Motif de refus"
            data-action="click->moderation-room#openRefusalReasonModal"
            data-refusal-reason="{{ entity.refusalReason }}"
        >ℹ️</button>
        {% endif %}
    </td>
</tr>
{% else %}
<tr>
    <td colspan="5" style="padding:1rem;text-align:center;color:var(--text-muted)">Aucune fiche trouvée.</td>
</tr>
{% endfor %}
