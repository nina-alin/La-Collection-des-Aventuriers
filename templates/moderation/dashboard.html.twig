{% extends 'base.html.twig' %}

{% block title %}Tableau de modération — La Collection{% endblock %}

{% block body %}
<div class="container" style="max-width:900px;margin:2rem auto;padding:0 1rem">
    <h1 style="margin-bottom:1.5rem">Tableau de modération</h1>

    <section style="margin-bottom:2rem">
        <h2>Entrées en attente</h2>
        {% if pendingEntries is empty %}
            <p style="color:var(--text-muted)">Aucune entrée en attente.</p>
        {% else %}
            {% for entry in pendingEntries %}
            <div style="border:1px solid var(--border-default);border-radius:var(--radius-md);padding:1rem;margin-bottom:1rem">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem">
                    <div>
                        <strong>{{ entry.title }}</strong>
                        <div style="font-size:.875rem;color:var(--text-muted);margin-top:.25rem">
                            Par {{ entry.author ? entry.author.pseudo : '[supprimé]' }}
                            · {{ entry.createdAt|date('d/m/Y H:i') }}
                        </div>
                    </div>
                    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                        <form method="POST" action="{{ path('moderation_approve_work_entry', {id: entry.id}) }}" style="margin:0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ entry.id) }}">
                            <button type="submit" class="btn btn-sm btn-primary">Approuver</button>
                        </form>
                        <form method="POST" action="{{ path('moderation_reject_work_entry', {id: entry.id}) }}" style="margin:0;display:flex;gap:.25rem">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ entry.id) }}">
                            <input type="text" name="reason" placeholder="Raison (optionnel)" style="font-size:.875rem;padding:.25rem .5rem;border:1px solid var(--border-default);border-radius:var(--radius-sm)">
                            <button type="submit" class="btn btn-sm btn-secondary">Rejeter</button>
                        </form>
                        <form method="POST" action="{{ path('moderation_edit_work_entry', {id: entry.id}) }}" style="margin:0;display:flex;gap:.25rem">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ entry.id) }}">
                            <input type="text" name="title" value="{{ entry.title }}" style="font-size:.875rem;padding:.25rem .5rem;border:1px solid var(--border-default);border-radius:var(--radius-sm)">
                            <button type="submit" class="btn btn-sm btn-ghost">Modifier</button>
                        </form>
                    </div>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </section>

    <section>
        <h2>Corrections en attente</h2>
        {% if pendingProposals is empty %}
            <p style="color:var(--text-muted)">Aucune correction en attente.</p>
        {% else %}
            {% for proposal in pendingProposals %}
            <div style="border:1px solid var(--border-default);border-radius:var(--radius-md);padding:1rem;margin-bottom:1rem">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem">
                    <div>
                        <strong>Correction pour : {{ proposal.workEntry.title }}</strong>
                        <div style="font-size:.875rem;color:var(--text-muted);margin-top:.25rem">
                            Par {{ proposal.author ? proposal.author.pseudo : '[supprimé]' }}
                            · {{ proposal.createdAt|date('d/m/Y H:i') }}
                        </div>
                    </div>
                    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                        <form method="POST" action="{{ path('moderation_approve_correction', {id: proposal.id}) }}" style="margin:0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ proposal.id) }}">
                            <button type="submit" class="btn btn-sm btn-primary">Approuver</button>
                        </form>
                        <form method="POST" action="{{ path('moderation_reject_correction', {id: proposal.id}) }}" style="margin:0;display:flex;gap:.25rem">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ proposal.id) }}">
                            <input type="text" name="reason" placeholder="Raison (optionnel)" style="font-size:.875rem;padding:.25rem .5rem;border:1px solid var(--border-default);border-radius:var(--radius-sm)">
                            <button type="submit" class="btn btn-sm btn-secondary">Rejeter</button>
                        </form>
                        <form method="POST" action="{{ path('moderation_edit_correction', {id: proposal.id}) }}" style="margin:0;display:flex;gap:.25rem">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('moderate_' ~ proposal.id) }}">
                            <input type="text" name="proposedContent" placeholder="Nouveau contenu" style="font-size:.875rem;padding:.25rem .5rem;border:1px solid var(--border-default);border-radius:var(--radius-sm)">
                            <button type="submit" class="btn btn-sm btn-ghost">Modifier</button>
                        </form>
                    </div>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </section>
</div>
{% endblock %}
