{% extends 'base.html.twig' %}

{% block title %}La Salle de Modération — La Collection{% endblock %}

{% block body %}
<div
    class="container"
    style="max-width:1280px;margin:2rem auto;padding:0 1.5rem"
    data-controller="moderation-room"
    data-moderation-room-pending-count-value="{{ pendingCount }}"
>
    <header style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;flex-wrap:wrap;gap:.5rem">
        <div>
            <p class="mod-eyebrow">
                {{ currentDate|date('d/m/Y') }}
                {% if pendingCount > 0 %} · {{ pendingCount }} suggestion{{ pendingCount > 1 ? 's' : '' }} en attente{% endif %}
            </p>
            <h1 class="mod-title">La Salle de Modération</h1>
        </div>
        <button
            class="btn btn-sm btn-ghost"
            style="margin-top:.25rem"
            data-action="click->moderation-room#toggleView"
            data-moderation-room-target="viewToggle"
            {% if pendingCount == 0 %}disabled{% endif %}
        >Vue Tableau</button>
    </header>

    {# ── Section II — Flux de traitement ──────────────────────────────────── #}
    <section style="margin-bottom:3rem">
        <div class="mod-section-head">
            <h2>↓ Flux de traitement</h2>
            <span style="font-family:var(--font-mono);font-size:var(--fs-xs);text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted)">
                1&nbsp;/&nbsp;{{ pendingCount }}
            </span>
        </div>
        <p class="mod-section-sub">Le cœur du travail. Une suggestion à la fois, focus maximal — la file est à droite.</p>

        <div data-moderation-room-target="fluxView">
            <div class="flux">
                <div class="diff-area" data-moderation-room-target="diffPanel">
                    {% include 'moderation/_diff_panel.html.twig' %}
                </div>
                {% include 'moderation/_queue_panel.html.twig' %}
            </div>
        </div>

        <div data-moderation-room-target="tableView" style="display:none">
            {% include 'moderation/_table_view.html.twig' %}
        </div>
    </section>

    {# ── Section III — Gestion globale des fiches ─────────────────────────── #}
    <section style="margin-bottom:2rem">
        <div class="mod-section-head">
            <h2>Gestion globale des fiches</h2>
        </div>
        <div class="entities-filter-bar">
            <input
                type="text"
                placeholder="Rechercher…"
                class="filter-search"
                data-moderation-room-target="searchInput"
                data-action="input->moderation-room#onSearchInput"
            >
            {% for label, typeValue in {'Tous': '', 'Livres': 'BOOK', 'Auteurs': 'AUTHOR', 'Illustrateurs': 'ILLUSTRATOR', 'Traducteurs': 'TRADUCTOR', 'Éditeurs': 'EDITOR', 'Collections': 'COLLECTION'} %}
                <button
                    class="btn btn-sm btn-ghost filter-btn"
                    data-action="click->moderation-room#filterByType"
                    data-type="{{ typeValue }}"
                >{{ label }}</button>
            {% endfor %}
        </div>
        <div style="overflow-x:auto">
            <table style="width:100%;border-collapse:collapse;font-size:.875rem">
                <thead>
                    <tr>
                        <th style="text-align:left;padding:.5rem .75rem;border-bottom:1px solid var(--border-default);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted);font-weight:500">Nom</th>
                        <th style="text-align:left;padding:.5rem .75rem;border-bottom:1px solid var(--border-default);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted);font-weight:500">Type</th>
                        <th style="text-align:left;padding:.5rem .75rem;border-bottom:1px solid var(--border-default);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted);font-weight:500">Statut</th>
                        <th style="text-align:left;padding:.5rem .75rem;border-bottom:1px solid var(--border-default);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted);font-weight:500">Dernière maj</th>
                        <th style="padding:.5rem .75rem;border-bottom:1px solid var(--border-default);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:var(--tracking-caps);color:var(--ink-muted);font-weight:500">Actions</th>
                    </tr>
                </thead>
                <tbody data-moderation-room-target="entitiesTableBody">
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
