{% extends 'base.html.twig' %}

{% block title %}Token Test — La Collection{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4" style="font-family: var(--font-display)">Design Token Verification</h1>
    <p class="text-muted mb-5">SC-001 — each swatch must match <code>design/assets/tokens.css</code> exactly.</p>

    <div class="row g-4">
        <div class="col-12 col-md-6">
            <h2 class="h5">Color — <code>--brand-primary</code></h2>
            <div style="background: var(--brand-primary); width: 100%; height: 80px; border-radius: var(--radius-md);">
                <span style="color: #fff; padding: 8px; font-size: 12px;">Expected: #8b4513</span>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <h2 class="h5">Typography — <code>--font-display</code></h2>
            <div style="font-family: var(--font-display); font-size: var(--fs-2xl); padding: 20px; background: var(--bg-elevated); border-radius: var(--radius-md);">
                Cinzel Display Font
            </div>
        </div>

        <div class="col-12 col-md-6">
            <h2 class="h5">Spacing — <code>--sp-4</code></h2>
            <div style="background: var(--bg-sunken); border-radius: var(--radius-md); padding: 8px;">
                <div style="background: var(--brand-primary); height: 20px; width: var(--sp-4);"></div>
                <small class="d-block mt-2 text-muted">Width = var(--sp-4)</small>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <h2 class="h5">Border Radius — <code>--radius-md</code></h2>
            <div style="background: var(--brand-secondary); width: 100px; height: 100px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 12px;">
                radius-md
            </div>
        </div>

        <div class="col-12">
            <h2 class="h5">Shadow — <code>--shadow-md</code></h2>
            <div style="background: var(--bg-base); box-shadow: var(--shadow-md); border-radius: var(--radius-md); padding: 24px; max-width: 400px;">
                Box shadow via <code>var(--shadow-md)</code>
            </div>
        </div>
    </div>
</div>
{% endblock %}
