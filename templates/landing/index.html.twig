{% extends 'base.html.twig' %}

{% block title %}La Collection des Aventuriers — Le wiki des livres dont vous êtes le héros{% endblock %}

{% block meta %}
    <meta name="description" content="Le catalogue collaboratif des livres dont vous êtes le héros : fiches, éditions, auteurs, illustrateurs, traducteurs.">
    <meta property="og:title" content="La Collection des Aventuriers">
    <meta property="og:description" content="Fiches, éditions, auteurs, illustrateurs, traducteurs. Un catalogue collaboratif des livres dont vous êtes le héros.">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:type" content="website">
{% endblock %}

{% block skip_link %}
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
{% endblock %}

{% block page_wrapper %}
<main id="main-content">

    {# =============== HERO =============== #}
    <section class="hero" {{ stimulus_controller('landing') }}>
        <div class="container">
            <div class="hero-inner">

                <span class="hero-eyebrow skeleton" {{ stimulus_target('landing', 'pilule') }}>
                    <span class="pulse"></span>
                    <span class="skeleton-text" style="width:260px;height:1em;display:inline-block;"></span>
                </span>

                <h1 class="hero-title">
                    La Collection des <em>Aventuriers</em>
                </h1>
                <p class="hero-sub">
                    Fiches, éditions, auteurs, illustrateurs, traducteurs. Un catalogue collaboratif.
                </p>

                <form class="hero-search" role="search"
                      {{ stimulus_target('landing', 'searchForm') }}>
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
                    <input type="search"
                           {{ stimulus_target('landing', 'searchInput') }}
                           placeholder="Rechercher un livre, un auteur, une collection…"
                           aria-label="Rechercher un titre"
                           inputmode="search"
                           autocomplete="off">
                    <button class="btn btn-primary btn-sm" type="submit" aria-label="Explorer le catalogue">
                        <span class="search-btn-label">Explorer</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                    </button>
                </form>

                <div class="search-suggestions-label">— EN CE MOMENT —</div>
                <div class="hero-marquee" {{ stimulus_target('landing', 'marqueeBlock') }} aria-label="Suggestions populaires">
                    <div class="marquee-track" {{ stimulus_target('landing', 'marqueeTrack') }}>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:120px"></span><span class="skeleton-line" style="width:80px"></span></span></div>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:100px"></span><span class="skeleton-line" style="width:70px"></span></span></div>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:140px"></span><span class="skeleton-line" style="width:90px"></span></span></div>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:110px"></span><span class="skeleton-line" style="width:75px"></span></span></div>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:130px"></span><span class="skeleton-line" style="width:85px"></span></span></div>
                        <div class="marquee-item skeleton" aria-hidden="true"><span class="marquee-cover skeleton-cover"></span><span class="marquee-text"><span class="skeleton-line" style="width:105px"></span><span class="skeleton-line" style="width:65px"></span></span></div>
                    </div>
                </div>

                <div class="hero-cta">
                    <a class="btn btn-primary btn-lg" href="{{ path('app_register') }}">
                        Nous rejoindre
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                    </a>
                    <a class="btn btn-ghost btn-lg" href="{{ path('app_catalogue') }}">Explorer le catalogue</a>
                </div>

            </div>
        </div>
    </section>

    {# =============== TROIS PILIERS =============== #}
    <section class="section">
        <div class="container">
            <h2 class="section-title">Collectionner, explorer, contribuer</h2>

            <div class="features-grid">
                <article class="feature">
                    <div class="feature-roman">— I —</div>
                    <div class="feature-eyebrow">Pour le collectionneur</div>
                    <h3 class="feature-title">Votre bibliothèque</h3>
                    <p class="feature-desc">
                        Notez ce que vous avez, ce qu'il vous manque, et distinguez les tirages des variantes de couverture. Pour les collectionneurs sérieux, ça fait la différence.
                    </p>
                    <ul class="feature-list">
                        <li>Listes d'envies et d'acquisitions, croisées par éditeur</li>
                        <li>Distinction tirage / réédition / variante de couverture</li>
                        <li>Export de votre bibliothèque (CSV, JSON)</li>
                        <li>Alertes ré-éditions et passages en occasion</li>
                    </ul>
                </article>

                <article class="feature">
                    <div class="feature-roman">— II —</div>
                    <div class="feature-eyebrow">Pour le passionné</div>
                    <h3 class="feature-title">Votre encyclopédie</h3>
                    <p class="feature-desc">
                        Auteurs, illustrateurs, traducteurs&nbsp;: chaque intervenant a sa page, avec les livres auxquels il a participé. Pratique pour remonter d'un livre à toute une œuvre.
                    </p>
                    <ul class="feature-list">
                        <li>Relations entre œuvres et créateurs</li>
                        <li>Variantes d'éditions documentées (FR, EN, JP, illustrations…)</li>
                        <li>Chronologies par série, par éditeur, par univers</li>
                        <li>Historique des modifications</li>
                    </ul>
                </article>

                <article class="feature">
                    <div class="feature-roman">— III —</div>
                    <div class="feature-eyebrow">Pour la communauté</div>
                    <h3 class="feature-title">Vos contributions</h3>
                    <p class="feature-desc">
                        Vous avez trouvé une erreur, une édition manquante ? Proposez une correction. Toutes les décisions de modération sont publiques et argumentées.
                    </p>
                    <ul class="feature-list">
                        <li>Système de suggestions avec suivi public</li>
                        <li>Modération motivée et historisée</li>
                        <li>Profils contributeurs avec statistiques</li>
                        <li>Accès au rôle de modérateur</li>
                    </ul>
                </article>
            </div>
        </div>
    </section>

    {# =============== ÉCOSYSTÈME =============== #}
    <section class="section ecosystem">
        <div class="container">
            <div class="section-eyebrow">Écosystème</div>
            <h2 class="section-title">Deux sites qui se complètent</h2>

            <div class="ecosystem-banner">
                <div class="eco-site">
                    <span class="eco-sigil lca">A</span>
                    <div>
                        <div class="eco-name">La Collection</div>
                        <div class="eco-role">Catalogue</div>
                    </div>
                    <p class="eco-desc">Le catalogue de référence&nbsp;: fiches, éditions, auteurs, illustrateurs, traducteurs...</p>
                </div>

                <div class="eco-bridge" aria-hidden="true">
                    <span class="eco-bridge-line"></span>
                    <span class="eco-bridge-label">— ET —</span>
                    <span class="eco-bridge-line"></span>
                </div>

                <div class="eco-site">
                    <span class="eco-sigil tav">T</span>
                    <div>
                        <div class="eco-name">La Taverne</div>
                        <div class="eco-role">Communauté</div>
                    </div>
                    <p class="eco-desc">L'endroit pour donner son avis, discuter d'une série, trouver d'autres passionnés.</p>
                </div>
            </div>
        </div>
    </section>

    {# =============== STATS / COMPTEURS =============== #}
    <section class="section stats" {{ stimulus_controller('counter') }} aria-label="Statistiques de la plateforme" aria-live="polite">
        <div class="container stats-inner">
            <div class="stat-eyebrow">L'archive en mouvement<span class="stat-tick"></span></div>
            <div class="stat">
                <span class="stat-number" {{ stimulus_target('counter', 'number') }} data-target="0">0</span>
                <span class="stat-label">Livres répertoriés</span>
            </div>
            <div class="stat">
                <span class="stat-number" {{ stimulus_target('counter', 'number') }} data-target="0">0</span>
                <span class="stat-label">Aventuriers inscrits</span>
            </div>
            <div class="stat">
                <span class="stat-number" {{ stimulus_target('counter', 'number') }} data-target="0">0</span>
                <span class="stat-label">Créateurs référencés</span>
            </div>
        </div>
    </section>

    {# =============== CTA FINAL =============== #}
    <section class="cta-final">
        <div class="container">
            <h2>Vous voulez un compte&nbsp;?</h2>
            <p>Gratuit, sans engagement. Vous contribuez si vous en avez envie.</p>
            <div class="hero-cta">
                <a class="btn btn-primary btn-lg" href="{{ path('app_register') }}">
                    Nous rejoindre
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
                <a class="btn btn-secondary btn-lg" href="{{ path('app_catalogue') }}">Voir le catalogue</a>
            </div>
        </div>
    </section>

</main>
{% endblock %}
