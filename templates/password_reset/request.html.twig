<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mot de passe oublié — La Collection des Aventuriers</title>
  {{ encore_entry_link_tags('app') }}
  {{ encore_entry_link_tags('auth') }}
</head>
<body>
<div class="auth" data-screen-label="Mot de passe oublié">

  <!-- ============ COUVERTURE (gauche) ============ -->
  <aside class="auth-cover" aria-hidden="true">
    <div class="auth-cover-inner">
      <a class="auth-cover-brand" href="{{ path('home') }}">
        <span class="auth-cover-sigil">A</span>
        <span class="auth-cover-brand-text">
          <span class="auth-cover-brand-title">La Collection des Aventuriers</span>
          <span class="auth-cover-brand-sub">Le wiki des fictions interactives</span>
        </span>
      </a>

      <div>
        <div class="auth-cover-eyebrow">Pas de panique</div>
        <h2 class="auth-cover-headline">Un sortilège pour <em>rouvrir</em> le grimoire.</h2>
        <p class="auth-cover-lede">
          Indique ton adresse e-mail et nous t'enverrons un lien sécurisé
          pour choisir un nouveau mot de passe.
        </p>
      </div>

      <ul class="auth-cover-list">
        <li>
          <span class="tick"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
          <span>Lien valable <strong>30 minutes</strong>, à usage unique.</span>
        </li>
        <li>
          <span class="tick"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
          <span>Ta collection reste <strong>intacte</strong> et privée.</span>
        </li>
      </ul>
    </div>

    <div class="auth-cover-stats">
      <div>
        <span class="stat-num">256-bit</span>
        <span class="stat-label">Chiffrement</span>
      </div>
      <div>
        <span class="stat-num">30 min</span>
        <span class="stat-label">Validité du lien</span>
      </div>
    </div>
  </aside>

  <!-- ============ FORMULAIRE (droite) ============ -->
  <main class="auth-content">
    <div class="auth-topbar">
      <div class="auth-topbar-spacer"></div>
      <div class="auth-switch">
        <span class="muted">Tu t'en souviens&nbsp;?</span>
        <a class="btn btn-secondary btn-sm" href="{{ path('app_login') }}">Se connecter</a>
      </div>
      <button class="auth-theme-toggle" data-theme-toggle aria-label="Basculer le thème">
        <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <div class="auth-body">
      {% set flash_sent = app.flashes('sent') %}
      {% if state == 'sent' or flash_sent|length > 0 %}
        <!-- vue confirmation -->
        <div class="auth-card">
          <div class="auth-confirm-icon success">
            <svg viewBox="0 0 24 24"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </div>
          <div class="auth-eyebrow">Lien envoyé</div>
          <h1 class="auth-title">Consulte ta boîte e-mail</h1>
          <p class="auth-subtitle">
            Si un compte existe pour cette adresse, un lien de réinitialisation
            vient d'y être envoyé. Il expire dans 30&nbsp;minutes.
          </p>
          <a class="btn btn-secondary btn-lg btn-block" href="{{ path('app_login') }}">
            ← Retour à la connexion
          </a>
          <p class="auth-resend">
            Rien dans ta boîte&nbsp;? Vérifie les indésirables, ou
            <form method="POST" action="{{ path('app_password_reset_resend') }}" style="display:inline;">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token('password_reset_resend') }}">
              <button type="submit">renvoyer le lien</button>
            </form>.
          </p>
          <div class="auth-foot">
            <a href="{{ path('app_login') }}">← Retour à la connexion</a>
          </div>
        </div>

      {% else %}
        <!-- vue formulaire -->
        <div class="auth-card">
          <a class="auth-mini-brand" href="{{ path('home') }}">
            <span class="sigil">A</span>
            <span class="txt">La Collection<br>des Aventuriers</span>
          </a>

          <div class="auth-eyebrow">Récupération</div>
          <h1 class="auth-title">Mot de passe oublié&nbsp;?</h1>
          <p class="auth-subtitle">Saisis l'adresse e-mail liée à ton compte. Nous t'enverrons un lien de réinitialisation.</p>

          {% if error %}
            <div class="auth-note error" role="alert">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>{{ error }}</span>
            </div>
          {% endif %}

          <form method="POST" action="{{ path('app_password_reset_request') }}" novalidate
                data-controller="auth-submit"
                data-action="submit->auth-submit#submit">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('password_reset_request') }}">

            <div class="form-group">
              <label class="form-label" for="email">Adresse e-mail</label>
              <input class="input" type="email" id="email" name="email"
                     autocomplete="email" placeholder="aventurier@exemple.fr" required
                     aria-describedby="{% if error %}pw-error{% endif %}">
            </div>

            <button class="btn btn-primary btn-lg btn-block auth-submit" type="submit"
                    data-auth-submit-target="button">
              <span data-auth-submit-target="label">
                Envoyer le lien
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </button>
          </form>

          <div class="auth-foot">
            <a href="{{ path('app_login') }}">← Retour à la connexion</a>
          </div>
        </div>
      {% endif %}
    </div>

    <footer class="auth-legal">
      <span>© {{ "now"|date("Y") }} · La Collection des Aventuriers</span>
      <div class="auth-legal-links">
        <a href="#">Aide</a>
        <a href="/politique-de-confidentialite">Confidentialité</a>
        <a href="#">CGU</a>
      </div>
    </footer>
  </main>
</div>

{{ encore_entry_script_tags('app') }}
</body>
</html>
