<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nouveau mot de passe — La Collection des Aventuriers</title>
  <script>(function(){var t=localStorage.getItem('theme');if(t==='dark'){document.documentElement.setAttribute('data-theme','dark');}})();</script>
  {{ encore_entry_link_tags('app') }}
  {{ encore_entry_link_tags('auth') }}
</head>
<body data-controller="theme">
<div class="auth" data-screen-label="Réinitialiser le mot de passe">

  <!-- ============ COUVERTURE (gauche) ============ -->
  <aside class="auth-cover" aria-hidden="true">
    <div class="auth-cover-inner">
      <a class="auth-cover-brand" href="{{ path('home') }}">
        <span class="auth-cover-sigil">A</span>
        <span class="auth-cover-brand-text">
          <span class="auth-cover-brand-title">La Collection des Aventuriers</span>
          <span class="auth-cover-brand-sub">Le wiki des fictions interactives</span>
        </span>
      </a>

      <div>
        <div class="auth-cover-eyebrow">Dernière étape</div>
        <h2 class="auth-cover-headline">Scelle ton compte d'un nouveau <em>sceau</em>.</h2>
        <p class="auth-cover-lede">
          Choisis un mot de passe solide. Lui seul rouvrira désormais
          ton grimoire personnel.
        </p>
      </div>

      <ul class="auth-cover-list">
        <li>
          <span class="tick"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
          <span>Toutes tes <strong>sessions actives</strong> seront déconnectées.</span>
        </li>
        <li>
          <span class="tick"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
          <span>Choisis un mot de passe <strong>unique</strong> à ce site.</span>
        </li>
      </ul>
    </div>

    <div class="auth-cover-stats">
      <div>
        <span class="stat-num">12+</span>
        <span class="stat-label">Caractères conseillés</span>
      </div>
      <div>
        <span class="stat-num">1×</span>
        <span class="stat-label">Lien à usage unique</span>
      </div>
    </div>
  </aside>

  <!-- ============ FORMULAIRE (droite) ============ -->
  <main class="auth-content">
    <div class="auth-topbar">
      <div class="auth-topbar-spacer"></div>
      <div class="auth-switch">
        <a class="btn btn-secondary btn-sm" href="{{ path('app_login') }}">Se connecter</a>
      </div>
      <button class="auth-theme-toggle" data-action="click->theme#toggle" aria-label="Basculer le thème">
        <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <div class="auth-body">

      {% if state == 'success' %}
        <!-- vue succès -->
        <div class="auth-card">
          <div class="auth-confirm-icon success">
            <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div class="auth-eyebrow">C'est scellé</div>
          <h1 class="auth-title">Mot de passe mis à jour</h1>
          <p class="auth-subtitle">
            Ton nouveau sceau est enregistré. Tu peux dès maintenant te reconnecter
            et rouvrir ta collection.
          </p>
          <a class="btn btn-primary btn-lg btn-block" href="{{ path('app_login') }}">
            Se connecter
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

      {% elseif state == 'invalid' %}
        <!-- vue lien invalide -->
        <div class="auth-card">
          <div class="auth-confirm-icon error" style="color:var(--danger);border-color:var(--danger-border);background:var(--danger-bg);">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <div class="auth-eyebrow">Lien expiré</div>
          <h1 class="auth-title">Ce lien est invalide</h1>
          <p class="auth-subtitle">
            Ce lien de réinitialisation a expiré ou a déjà été utilisé.
            Demande un nouveau lien.
          </p>
          <a class="btn btn-primary btn-lg btn-block" href="{{ path('app_password_reset_request') }}">
            Demander un nouveau lien
          </a>
          <div class="auth-foot">
            <a href="{{ path('app_login') }}">← Retour à la connexion</a>
          </div>
        </div>

      {% else %}
        <!-- vue formulaire -->
        <div class="auth-card">
          <a class="auth-mini-brand" href="{{ path('home') }}">
            <span class="sigil">A</span>
            <span class="txt">La Collection<br>des Aventuriers</span>
          </a>

          <div class="auth-eyebrow">Réinitialisation</div>
          <h1 class="auth-title">Nouveau mot de passe</h1>
          <p class="auth-subtitle">Choisis un mot de passe que tu n'utilises nulle part ailleurs.</p>

          {% if error %}
            <div class="auth-note error" role="alert" id="reset-error">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>{{ error }}</span>
            </div>
          {% endif %}

          <form method="POST" action="{{ path('app_password_reset') }}" novalidate
                data-controller="auth-submit"
                data-action="submit->auth-submit#submit">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">
            <input type="hidden" name="token" value="{{ token }}">

            <div class="form-group" data-controller="auth-password">
              <label class="form-label" for="plainPassword">
                Nouveau mot de passe <span class="required" aria-hidden="true">*</span>
              </label>
              <div class="input-affix">
                <input class="input" type="password" id="plainPassword" name="plainPassword"
                       autocomplete="new-password" placeholder="Nouveau mot de passe" required
                       data-auth-password-target="input"
                       data-action="input->auth-password#score"
                       aria-describedby="{% if error %}reset-error{% endif %}">
                <button type="button" class="affix-btn" aria-pressed="false" aria-label="Afficher le mot de passe"
                        data-auth-password-target="toggle"
                        data-action="click->auth-password#toggle">
                  <svg class="eye" viewBox="0 0 24 24"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="eye-off" viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19M1 1l22 22"/></svg>
                </button>
              </div>
              <div class="pw-meter" id="pw-meter" data-score="0" data-auth-password-target="meter">
                <div class="pw-meter-bars"><span></span><span></span><span></span><span></span></div>
                <div class="pw-meter-label"><span>Robustesse</span><span class="lvl" data-auth-password-target="meterLabel">—</span></div>
              </div>
              <ul class="pw-reqs" id="pw-reqs" data-auth-password-target="reqs">
                <li data-req="len"><span class="check"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>8 caractères min.</li>
                <li data-req="case"><span class="check"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>Maj. &amp; min.</li>
                <li data-req="num"><span class="check"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>Un chiffre</li>
                <li data-req="sym"><span class="check"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>Un symbole</li>
              </ul>
            </div>

            <div class="form-group">
              <label class="form-label" for="passwordConfirm">
                Confirmer le mot de passe <span class="required" aria-hidden="true">*</span>
              </label>
              <div class="input-affix" data-controller="auth-password">
                <input class="input" type="password" id="passwordConfirm" name="passwordConfirm"
                       autocomplete="new-password" placeholder="Répète le mot de passe" required
                       data-auth-password-target="input"
                       aria-describedby="{% if error %}reset-error{% endif %}">
                <button type="button" class="affix-btn" aria-pressed="false" aria-label="Afficher le mot de passe"
                        data-auth-password-target="toggle"
                        data-action="click->auth-password#toggle">
                  <svg class="eye" viewBox="0 0 24 24"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="eye-off" viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19M1 1l22 22"/></svg>
                </button>
              </div>
            </div>

            <button class="btn btn-primary btn-lg btn-block auth-submit" type="submit"
                    data-auth-submit-target="button">
              <span data-auth-submit-target="label">Enregistrer le nouveau mot de passe</span>
            </button>
          </form>

          <div class="auth-foot">
            <a href="{{ path('app_login') }}">← Retour à la connexion</a>
          </div>
        </div>
      {% endif %}

    </div>

    <footer class="auth-legal">
      <span>© {{ "now"|date("Y") }} · La Collection des Aventuriers</span>
      <div class="auth-legal-links">
        <a href="#">Aide</a>
        <a href="/politique-de-confidentialite">Confidentialité</a>
        <a href="#">CGU</a>
      </div>
    </footer>
  </main>
</div>

{{ encore_entry_script_tags('app') }}
</body>
</html>
