{% extends 'base.html.twig' %}

{% block title %}{{ collection.nom }}{% if currentPage > 1 %} (page {{ currentPage }}){% endif %} — La Collection dont vous êtes le héros{% endblock %}

{% block meta %}
    <link rel="canonical" href="{{ path('app_collection_show', {slug: collection.slug}) }}">
    <meta name="description" content="{{ collection.description|slice(0, 157) }}{{ collection.description|length > 157 ? '…' : '' }}">
{% endblock %}

{% block body %}
<div class="container">

    {# Breadcrumb #}
    <nav class="crumbs" aria-label="Fil d'Ariane">
        <a href="{{ path('app_catalogue') }}">Catalogue</a>
        <span class="sep">›</span>
        <a href="{{ path('app_catalogue') }}">Collections</a>
        <span class="sep">›</span>
        <span class="here">{{ collection.nom }}</span>
    </nav>

    {# ============================== HERO ============================== #}
    <section class="coll-hero" aria-labelledby="coll-title">

        {# Emblem #}
        <div class="coll-emblem" aria-hidden="true">
            <div class="coll-emblem-inner">
                {% if collection.imageLogo %}
                    <img src="{{ asset('uploads/collections/' ~ collection.imageLogo) }}"
                         alt="{{ collection.nom }}"
                         style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
                {% else %}
                    <span class="coll-emblem-glyph">{{ collection.nom|slice(0,2)|upper }}</span>
                {% endif %}
            </div>
            {% if heroMeta.yearMin is not null %}
                <span class="coll-emblem-ribbon">Collection · {{ heroMeta.yearMin }}{% if heroMeta.yearMax and heroMeta.yearMax != heroMeta.yearMin %} — {{ heroMeta.yearMax }}{% endif %}</span>
            {% else %}
                <span class="coll-emblem-ribbon">Collection</span>
            {% endif %}
        </div>

        {# Content #}
        <div class="coll-content">
            <div class="coll-eyebrow">
                <span>Série · {{ collection.genre.value }}</span>
            </div>

            <h1 class="coll-title" id="coll-title">{{ collection.nom }}</h1>

            {% if collection.nomOriginal %}
                <p class="coll-title-original">
                    <span class="label">V.O.</span>{{ collection.nomOriginal }}
                </p>
            {% endif %}

            <dl class="coll-meta">
                <div>
                    <dt>Tomes recensés</dt>
                    <dd>{{ totalBooks }} <span class="out">volumes</span></dd>
                </div>
                <div>
                    <dt>Période</dt>
                    <dd>
                        {% if heroMeta.yearMin is not null and heroMeta.yearMax is not null %}
                            {% if heroMeta.yearMin == heroMeta.yearMax %}
                                {{ heroMeta.yearMin }}
                            {% else %}
                                {{ heroMeta.yearMin }} — {{ heroMeta.yearMax }}
                            {% endif %}
                        {% elseif heroMeta.yearMin is not null %}
                            {{ heroMeta.yearMin }}
                        {% else %}
                            <span class="out">–</span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt>Note moyenne série</dt>
                    <dd>
                        {% if heroMeta.averageRating is not null %}
                            {{ heroMeta.averageRating|number_format(1, ',') }} <span class="out">/ 10</span>
                        {% else %}
                            <span class="out">–</span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt>Statut éditorial</dt>
                    <dd>{{ collection.statut.value|replace({'-': ' '})|capitalize }}</dd>
                </div>
            </dl>

            <div class="coll-cta">
                <a href="#" class="btn btn-ghost">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                    Suggérer un tome manquant
                </a>
                {% if app.user %}
                    <a href="{{ path('suggestions_index', {entityType: 'COLLECTION', entityId: collection.id}) }}"
                       class="btn btn-ghost">
                        Suggérer une correction
                    </a>
                {% endif %}
                {% if is_granted('ROLE_USER') %}
                    {% if isSubscribed %}
                        <form method="post" action="{{ path('collection_unsubscribe', {id: collection.id}) }}" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('collection_subscribe_' ~ collection.id) }}">
                            <button type="submit" class="btn btn-ghost btn-ghost--active">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                Suivi
                            </button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('collection_subscribe', {id: collection.id}) }}" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('collection_subscribe_' ~ collection.id) }}">
                            <button type="submit" class="btn btn-ghost">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                Suivre
                            </button>
                        </form>
                    {% endif %}
                {% endif %}
            </div>

            {# ============================== COMPLETION (US3) ============================== #}
            {% if ownedCount is not null %}
                {% set missingCount = totalBooks - ownedCount %}
                {% set pct = totalBooks > 0 ? (ownedCount / totalBooks * 100)|round(1) : 0 %}
                <div class="progress-card" aria-labelledby="progress-label">
                    <div class="progress-head">
                        <div class="progress-head-left">
                            <span class="progress-title" id="progress-label">Votre quête de complétion</span>
                            <span class="progress-pct">{{ pct|number_format(1, ',') }} %</span>
                        </div>
                        <div class="progress-numbers">
                            <span class="have">{{ ownedCount }}</span><span class="sep">/</span><span class="total">{{ totalBooks }}</span>
                            <span class="lbl">tomes possédés</span>
                        </div>
                    </div>
                    <div class="progress-track"
                         role="progressbar"
                         aria-valuemin="0"
                         aria-valuemax="{{ totalBooks }}"
                         aria-valuenow="{{ ownedCount }}"
                         aria-valuetext="{{ ownedCount }} sur {{ totalBooks }} tomes possédés">
                        <div class="progress-fill" style="width: {{ pct }}%;"></div>
                        <div class="progress-ticks" style="--tomes: {{ totalBooks }};">
                            {% for i in 1..totalBooks %}<span></span>{% endfor %}
                        </div>
                    </div>
                    <div class="progress-foot">
                        {% if missingCount == 0 %}
                            <span class="quest">Vous possédez tous les tomes de {{ collection.nom }}. Quête accomplie !</span>
                        {% else %}
                            <span class="quest">Il vous manque <strong>{{ missingCount }} tome{{ missingCount > 1 ? 's' : '' }}</strong> pour boucler la saga {{ collection.nom }}.</span>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="progress-card progress-card--guest" aria-labelledby="progress-label">
                    <div class="progress-head">
                        <div class="progress-head-left">
                            <span class="progress-title" id="progress-label">Votre quête de complétion</span>
                        </div>
                    </div>
                    <div class="progress-foot">
                        <span class="quest"><a href="{{ path('app_login') }}">Connectez-vous</a> pour suivre votre progression dans cette collection.</span>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>

    {# ============================== TOMES (US2) ============================== #}
    <section class="tomes-section" aria-labelledby="tomes-title"
             data-controller="collection-sort">
        <div class="tomes-head">
            <h2 class="tomes-title" id="tomes-title">
                Les Tomes <span class="num">{{ totalBooks }} volumes</span>
            </h2>

            <div class="tomes-controls">
                <div class="filter-pills" role="group" aria-label="Filtrer par statut">
                    <button class="filter-pill" data-kind="all" aria-pressed="true" type="button">
                        <span class="dot" aria-hidden="true"></span>
                        Tous <span class="count">{{ totalBooks }}</span>
                    </button>
                    <button class="filter-pill" data-kind="owned" aria-pressed="false" type="button" disabled>
                        <span class="dot" aria-hidden="true"></span>
                        Possédés
                    </button>
                    <button class="filter-pill" data-kind="missing" aria-pressed="false" type="button" disabled>
                        <span class="dot" aria-hidden="true"></span>
                        Manquants
                    </button>
                </div>

                <div class="seg" role="group" aria-label="Trier les tomes">
                    <button type="button"
                            aria-pressed="true"
                            data-sort="volume"
                            data-action="collection-sort#sortByVolume">
                        <svg viewBox="0 0 24 24"><path d="M4 6h12M4 12h9M4 18h6"/><path d="M18 14l3 3-3 3"/></svg>
                        Numéro
                    </button>
                    <button type="button"
                            aria-pressed="false"
                            data-sort="rating"
                            data-action="collection-sort#sortByRating">
                        <svg viewBox="0 0 24 24"><path d="M12 2l3.1 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.8 21l1.2-6.8-5-4.9 6.9-1z"/></svg>
                        Note
                    </button>
                </div>
            </div>
        </div>

        <div class="tomes-grid" data-collection-sort-target="grid">
            {% for book in books %}
                {% set hues = ['forest','storm','ember','amber','ink','gold'] %}
                {% set hue = hues[(book.volumeNumber ?? 0) % 6] %}
                {% set avgRating = '' %}
                {% if book.reviews|length > 0 %}
                    {% set total = 0 %}
                    {% for review in book.reviews %}{% set total = total + review.score %}{% endfor %}
                    {% set avgRating = (total / book.reviews|length)|round(1) %}
                {% endif %}
                {% set isOwned = ownedBookIds is not null and book.id in ownedBookIds %}
                {% set isMissing = ownedBookIds is not null and not isOwned %}
                {% set isInWishlist = toBuyBookIds is not null and book.id in toBuyBookIds %}

                <div class="tome-wrap"
                     data-volume="{{ book.volumeNumber ?? 0 }}"
                     data-rating="{{ avgRating }}">
                    <div class="tome{{ isMissing ? ' tome--missing' : '' }}"
                         data-hue="{{ hue }}">
                        <div class="tome-cover">
                            <span class="tome-cover-frame" aria-hidden="true"></span>
                            {% if book.volumeNumber %}
                                <span class="tome-num">Tome <strong>{{ book.volumeNumber }}</strong></span>
                            {% endif %}
                            {% if isOwned %}
                                <span class="tome-status tome-status--owned" aria-label="Possédé">
                                    <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                                </span>
                            {% else %}
                                <span class="tome-missing-mark" aria-label="{{ ownedBookIds is not null ? 'Non possédé' : 'Statut inconnu' }}">?</span>
                            {% endif %}
                            <span class="tome-title-art">{{ book.title }}</span>
                        </div>
                        {% if isInWishlist %}
                            <div class="tome-wishlist-bar">
                                <span class="tome-wishlist-label">
                                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                                    Dans ma liste d'achat
                                </span>
                                <button type="submit" form="wl-{{ book.id }}" class="tome-wishlist-btn">Retirer</button>
                            </div>
                        {% endif %}
                        <div class="tome-body">
                            <div class="tome-ref">
                                <span>{% if book.volumeNumber %}T{{ '%02d'|format(book.volumeNumber) }}{% endif %}{% if book.frenchPublicationYear %} · {{ book.frenchPublicationYear }}{% endif %}</span>
                                {% if book.paragraphs %}<span>{{ book.paragraphs }} §</span>{% endif %}
                            </div>
                            <div class="tome-title">{{ book.title }}</div>
                            <div class="tome-meta">
                                <span class="tome-score">
                                    {% if avgRating != '' %}
                                        <span class="star">★</span>{{ avgRating }}<span class="out">/10</span>
                                    {% else %}
                                        <span class="out">–</span>
                                    {% endif %}
                                </span>
                                <span class="tome-year">
                                    {% set authorNames = [] %}
                                    {% for contribution in book.contributions %}
                                        {% if contribution.deletedAt is null %}
                                            {% set authorNames = authorNames|merge([contribution.contributor.firstName ~ ' ' ~ contribution.contributor.lastName]) %}
                                        {% endif %}
                                    {% endfor %}
                                    {{ authorNames|join(' · ') }}
                                </span>
                            </div>
                        </div>
                        <a class="tome-link" href="{{ path('app_book_show', {slug: book.slug}) }}" aria-label="{{ book.title }}"></a>
                    </div>
                    {% if isInWishlist %}
                        <form id="wl-{{ book.id }}" method="post" action="{{ path('app_userbook_remove_wishlist', {id: book.id}) }}" hidden>
                            <input type="hidden" name="_token" value="{{ csrf_token('remove_wishlist_' ~ book.id) }}">
                        </form>
                    {% endif %}
                </div>
            {% else %}
                <p class="collection-empty">Aucun tome disponible</p>
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
            <nav class="pagination" aria-label="Pagination">
                {% if currentPage > 1 %}
                    <a class="pagination-prev" href="{{ path('app_collection_show', {slug: collection.slug, page: currentPage - 1}) }}">← Précédent</a>
                {% endif %}
                <span class="pagination-info">Page {{ currentPage }} / {{ totalPages }}</span>
                {% if currentPage < totalPages %}
                    <a class="pagination-next" href="{{ path('app_collection_show', {slug: collection.slug, page: currentPage + 1}) }}">Suivant →</a>
                {% endif %}
            </nav>
        {% endif %}
    </section>

    {# ============================== EXTRA PANELS ============================== #}
    <section class="extra" aria-label="Informations complémentaires">

        {# ============================== PUBLISHING HISTORY (US4) ============================== #}
        {% if publishingHistory|length > 1 %}
            <div class="panel" aria-labelledby="editors-title">
                <div class="panel-head">
                    <h2 class="panel-title" id="editors-title">Éditeurs successifs</h2>
                    <span class="panel-sub">{{ publishingHistory|length }} entrées</span>
                </div>
                <div class="editors-list">
                    {% for entry in publishingHistory %}
                        <div class="editor-row">
                            <div class="editor-period">
                                <strong>{{ entry.startYear }}{% if entry.endYear %} — {{ entry.endYear }}{% else %} — …{% endif %}</strong>
                                {% if entry.editionName %}{{ entry.editionName }}{% endif %}
                            </div>
                            <div class="editor-body">
                                {% if entry.editor %}
                                    <span class="editor-tag">
                                        <span class="crest">{{ entry.editor.name|slice(0,2)|upper }}</span>
                                        {{ entry.editor.name }}
                                    </span>
                                {% else %}
                                    <span class="editor-tag">
                                        <span class="crest">?</span>
                                        (éditeur inconnu)
                                    </span>
                                {% endif %}
                                {% if entry.details %}
                                    <span class="editor-stat">{{ entry.details }}</span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# ============================== CONTRIBUTORS (US5) ============================== #}
        {% if recurringContributors.pills|length > 0 %}
            <div class="panel" aria-labelledby="authors-title">
                <div class="panel-head">
                    <h2 class="panel-title" id="authors-title">Auteurs &amp; illustrateurs récurrents</h2>
                    <span class="panel-sub">{{ recurringContributors.uniqueCount }} contributeur{{ recurringContributors.uniqueCount > 1 ? 's' : '' }}</span>
                </div>
                <div class="authors-cloud">
                    {% set roleRoutes = {'Author': 'app_author_show', 'Illustrator': 'app_illustrator_show', 'Traductor': 'app_traductor_show'} %}
                    {% for pill in recurringContributors.pills %}
                        <a href="{{ path(roleRoutes[pill.role.value] ?? 'app_author_show', {slug: pill.contributor.slug}) }}" class="author-tag">
                            <span class="avatar">{{ pill.initials }}</span>
                            {{ pill.contributor.firstName }} {{ pill.contributor.lastName }}
                            <span class="role">{{ pill.role.value|upper }}</span>
                            <span class="count">{{ pill.count }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    </section>

</div>
{% endblock %}
