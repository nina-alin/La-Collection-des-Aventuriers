# Copy this file to .env.local and fill in the required values.
# Generate APP_SECRET with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=

# DATABASE_URL: hostname MUST be 'database' (Docker service name, not 127.0.0.1)
DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=16&charset=utf8"

# PostgreSQL credentials — must match DATABASE_URL above
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=!ChangeMe!

# Host ports — change to resolve conflicts (e.g. APP_PORT=8080)
APP_PORT=8000
DB_PORT=5432

# Xdebug — set to 'debug' to enable step debugging (no container rebuild needed)
XDEBUG_MODE=off

# Google OAuth2 — register http://localhost:${APP_PORT}/auth/google/callback as redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
